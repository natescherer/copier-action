{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "act@0.2.84",
    "actionlint@1.7.12",
    "difftastic@0.68.0",
    "editorconfig-checker@3.6.1",
    "git@2.53.0",
    "prettier@3.6.2",
    "shellcheck@0.11.0",
    "uv@0.10.12"
  ],
  "env": {
    "GIT_EXTERNAL_DIFF": "difft"
  },
  "shell": {
    "init_hook": ["uv sync --frozen", "uv run pre-commit install"],
    "scripts": {
      "test": ["act -W .github/workflows/ci.yml"]
    }
  }
}
